# Core service
CORE_PORT=3000
MONGODB_URI=mongodb://localhost:27017/stock_market_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SECONDS=300

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_NOTIFICATIONS_EXCHANGE=notifications

# JWT
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Seeded CMS administrator
CMS_ADMIN_EMAIL=admin@example.com
CMS_ADMIN_PASSWORD=replace_with_admin_password
CMS_ADMIN_FULL_NAME=System Administrator

# Auth rate limiting
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=10

# Gmail SMTP email provider
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=replace_with_gmail_app_password
EMAIL_FROM=your_gmail_address@gmail.com

# Stripe
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# Notification service
NOTIFICATION_PORT=3001

# API gateway
GATEWAY_PORT=8080
CORE_SERVICE_URL=http://localhost:3000
NOTIFICATION_SERVICE_URL=http://localhost:3001
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_MAX_REQUESTS=120
GATEWAY_PROXY_TIMEOUT_MS=30000
