        { "name": "Transactions", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{memberAccessToken}}" }], "url": "{{gatewayBaseUrl}}/wallet/transactions?type=deposit&from=2026-05-01&to=2026-05-31" }, "response": [{ "name": "Success", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/wallet/transactions" }, "status": "OK", "code": 200, "body": "{\n  \"success\": true,\n  \"data\": [{ \"type\": \"deposit\", \"amount\": 1000 }]\n}" }, { "name": "Invalid Token", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/wallet/transactions" }, "status": "Unauthorized", "code": 401, "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Invalid bearer token\"\n}" }] }
      ]
