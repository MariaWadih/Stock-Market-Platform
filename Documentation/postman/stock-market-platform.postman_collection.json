  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Member",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayBaseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Adam Haddad\",\n  \"email\": \"adam@example.com\",\n  \"nationalId\": \"LBN-1990-0001\",\n  \"dateOfBirth\": \"1990-05-15\"\n}"
            }
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/register" },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"message\": \"OTP sent to email\"\n  }\n}"
            },
            {
              "name": "Validation Error",
              "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/register" },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"statusCode\": 400,\n  \"message\": [\"email must be an email\"]\n}"
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayBaseUrl}}/auth/verify-otp",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"adam@example.com\",\n  \"code\": \"123456\"\n}" }
          },
          "response": [
            { "name": "Success", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/verify-otp" }, "status": "Created", "code": 201, "body": "{\n  \"success\": true,\n  \"data\": {\n    \"message\": \"OTP verified\"\n  }\n}" },
            { "name": "Invalid OTP", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/verify-otp" }, "status": "Bad Request", "code": 400, "body": "{\n  \"success\": false,\n  \"message\": \"Invalid or expired OTP\"\n}" }
          ]
        },
        {
          "name": "Set Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayBaseUrl}}/auth/set-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"adam@example.com\",\n  \"password\": \"StrongPass123!\"\n}" }
          },
          "response": [
            { "name": "Success", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/set-password" }, "status": "Created", "code": 201, "body": "{\n  \"success\": true,\n  \"data\": {\n    \"message\": \"Password set successfully\"\n  }\n}" },
            { "name": "Not Verified", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/set-password" }, "status": "Forbidden", "code": 403, "body": "{\n  \"success\": false,\n  \"message\": \"Email is not verified\"\n}" }
          ]
        },
        {
          "name": "Member Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayBaseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"adam@example.com\",\n  \"password\": \"StrongPass123!\"\n}" }
          },
          "response": [
            { "name": "Success", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/login" }, "status": "Created", "code": 201, "body": "{\n  \"success\": true,\n  \"data\": {\n    \"accessToken\": \"eyJ...\",\n    \"refreshToken\": \"eyJ...\",\n    \"user\": { \"type\": \"member\", \"email\": \"adam@example.com\" }\n  }\n}" },
            { "name": "Invalid Credentials", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/auth/login" }, "status": "Unauthorized", "code": 401, "body": "{\n  \"success\": false,\n  \"message\": \"Invalid credentials\"\n}" }
          ]
        },
        {
          "name": "CMS Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayBaseUrl}}/cms/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPass123!\"\n}" }
          },
          "response": [
            { "name": "Success", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/cms/auth/login" }, "status": "Created", "code": 201, "body": "{\n  \"success\": true,\n  \"data\": {\n    \"accessToken\": \"eyJ...\",\n    \"user\": { \"type\": \"cms\", \"role\": \"administrator\" }\n  }\n}" },
            { "name": "Invalid Credentials", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/cms/auth/login" }, "status": "Unauthorized", "code": 401, "body": "{\n  \"success\": false,\n  \"message\": \"Invalid credentials\"\n}" }
          ]
        }
      ]
