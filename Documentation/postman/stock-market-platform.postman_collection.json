    "description": "Requests are configured to hit the API gateway by default. Set gatewayBaseUrl to http://localhost:8080."
  },
  "variable": [
    { "key": "gatewayBaseUrl", "value": "http://localhost:8080" },
    { "key": "memberAccessToken", "value": "" },
    { "key": "cmsAccessToken", "value": "" },
    { "key": "stockId", "value": "665000000000000000000201" },
    { "key": "memberId", "value": "665000000000000000000001" },
    { "key": "withdrawalId", "value": "665000000000000000000701" },
    { "key": "priceAlertId", "value": "665000000000000000000801" }
