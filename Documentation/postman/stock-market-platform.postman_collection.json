    {
      "name": "Stocks",
      "item": [
        {
          "name": "List Listed Stocks",
          "request": { "method": "GET", "url": "{{gatewayBaseUrl}}/stocks" },
          "response": [
            { "name": "Success", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/stocks" }, "status": "OK", "code": 200, "body": "{\n  \"success\": true,\n  \"data\": [{ \"ticker\": \"AAPL\", \"currentPrice\": 182.63 }]\n}" },
            { "name": "Rate Limited", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/stocks" }, "status": "Too Many Requests", "code": 429, "body": "{\n  \"statusCode\": 429,\n  \"message\": \"Rate limit exceeded\"\n}" }
          ]
        },
        {
          "name": "Create Stock",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{cmsAccessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayBaseUrl}}/cms/stocks",
            "body": { "mode": "raw", "raw": "{\n  \"ticker\": \"NVDA\",\n  \"companyName\": \"NVIDIA Corporation\",\n  \"sector\": \"Technology\",\n  \"currentPrice\": 900,\n  \"description\": \"NVIDIA designs GPUs and AI computing platforms.\",\n  \"isListed\": true\n}" }
          },
          "response": [
            { "name": "Success", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/cms/stocks" }, "status": "Created", "code": 201, "body": "{\n  \"success\": true,\n  \"data\": { \"ticker\": \"NVDA\" }\n}" },
            { "name": "Unauthorized", "originalRequest": { "method": "POST", "url": "{{gatewayBaseUrl}}/cms/stocks" }, "status": "Unauthorized", "code": 401, "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Missing bearer token\"\n}" }
          ]
        },
        {
          "name": "Update Stock Price",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{cmsAccessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayBaseUrl}}/cms/stocks/{{stockId}}/price",
            "body": { "mode": "raw", "raw": "{\n  \"currentPrice\": 190.25\n}" }
          },
          "response": [
            { "name": "Success", "originalRequest": { "method": "PATCH", "url": "{{gatewayBaseUrl}}/cms/stocks/{{stockId}}/price" }, "status": "OK", "code": 200, "body": "{\n  \"success\": true,\n  \"data\": { \"currentPrice\": 190.25 }\n}" },
            { "name": "Forbidden", "originalRequest": { "method": "PATCH", "url": "{{gatewayBaseUrl}}/cms/stocks/{{stockId}}/price" }, "status": "Forbidden", "code": 403, "body": "{\n  \"success\": false,\n  \"message\": \"Forbidden resource\"\n}" }
          ]
        },
        {
          "name": "Price History",
          "request": { "method": "GET", "url": "{{gatewayBaseUrl}}/stocks/{{stockId}}/history" },
          "response": [
            { "name": "Success", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/stocks/{{stockId}}/history" }, "status": "OK", "code": 200, "body": "{\n  \"success\": true,\n  \"data\": [{ \"price\": 190.25, \"recordedAt\": \"2026-05-07T00:00:00.000Z\" }]\n}" },
            { "name": "Invalid ObjectId", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/stocks/not-an-id/history" }, "status": "Bad Request", "code": 400, "body": "{\n  \"success\": false,\n  \"message\": \"Invalid MongoDB ObjectId\"\n}" }
          ]
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        { "name": "My Profile", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{memberAccessToken}}" }], "url": "{{gatewayBaseUrl}}/members/me" }, "response": [{ "name": "Success", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/members/me" }, "status": "OK", "code": 200, "body": "{\n  \"success\": true,\n  \"data\": { \"email\": \"adam@example.com\", \"passwordHash\": null }\n}" }, { "name": "Unauthorized", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/members/me" }, "status": "Unauthorized", "code": 401, "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Missing bearer token\"\n}" }] },
        { "name": "CMS List Members", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{cmsAccessToken}}" }], "url": "{{gatewayBaseUrl}}/cms/members" }, "response": [{ "name": "Success", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/cms/members" }, "status": "OK", "code": 200, "body": "{\n  \"success\": true,\n  \"data\": [{ \"email\": \"adam@example.com\" }]\n}" }, { "name": "Forbidden", "originalRequest": { "method": "GET", "url": "{{gatewayBaseUrl}}/cms/members" }, "status": "Forbidden", "code": 403, "body": "{\n  \"success\": false,\n  \"message\": \"Forbidden resource\"\n}" }] },
        { "name": "Review Identity", "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{cmsAccessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": "{{gatewayBaseUrl}}/cms/members/{{memberId}}/identity", "body": { "mode": "raw", "raw": "{\n  \"status\": \"approved\"\n}" } }, "response": [{ "name": "Success", "originalRequest": { "method": "PATCH", "url": "{{gatewayBaseUrl}}/cms/members/{{memberId}}/identity" }, "status": "OK", "code": 200, "body": "{\n  \"success\": true,\n  \"data\": { \"identityVerificationStatus\": \"approved\" }\n}" }, { "name": "Invalid Review", "originalRequest": { "method": "PATCH", "url": "{{gatewayBaseUrl}}/cms/members/{{memberId}}/identity" }, "status": "Forbidden", "code": 403, "body": "{\n  \"success\": false,\n  \"message\": \"Identity review must approve or reject\"\n}" }] }
      ]
